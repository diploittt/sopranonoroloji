
# Valid Database URL (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/sopranochat?schema=public"

# CORS Origins (comma separated)
CORS_ORIGIN="http://localhost:3000,https://yourdomain.com"

# JWT Secret for Session/Auth
JWT_SECRET="super-secret-key-change-this"

# Admin Secret (Optional, if used)
ADMIN_SECRET="admin-secret-key"

# LiveKit Keys (If using LiveKit Cloud)
LIVEKIT_API_KEY="your-api-key"
LIVEKIT_API_SECRET="your-api-secret"
LIVEKIT_URL="wss://your-project.livekit.cloud"
